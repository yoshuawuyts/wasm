---
source: crates/component-frontend/src/components/ds/sigil.rs
expression: "crate::components::ds::pretty_html(&render(\"sigils\", \"25\", \"Sigils\",\n\"18\\u{00d7}18px rounded squares with a single monospace letter, used to classify items by kind in sidebars, item lists, and detail pages. Each sigil pairs a categorical background with its ink counterpart for 4.5:1 contrast.\",\nALL,))"
---
<section class="pt-12 md:pt-16" id="sigils">
  <div class="grid md:grid-cols-[600px_1fr] gap-6 md:gap-12">
    <div>
      <div class="text-[12px] mono uppercase tracking-wider text-ink-500">
        25
      </div>
      <h2 class="mt-2 text-[24px] font-semibold tracking-tight">
        Sigils
      </h2>
      <p class="mt-2 text-[13px] text-ink-500 leading-relaxed">
        18×18px rounded squares with a single monospace letter, used to classify items by kind in sidebars, item lists, and detail pages. Each sigil pairs a categorical background with its ink counterpart for 4.5:1 contrast.
      </p>
    </div>
    <div class="space-y-6">
      <div class="text-[12px] text-ink-500 mb-3">
        Legend
      </div>
      <div class="flex flex-wrap gap-4">
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-cream);color:var(--c-cat-cream-ink);">
            W
          </span>
          <span class="text-[11px] text-ink-500">
            World
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-rust);color:var(--c-cat-rust-ink);">
            I
          </span>
          <span class="text-[11px] text-ink-500">
            Interface
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-green);color:var(--c-cat-green-ink);">
            F
          </span>
          <span class="text-[11px] text-ink-500">
            Function
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-blue);color:var(--c-cat-blue-ink);">
            T
          </span>
          <span class="text-[11px] text-ink-500">
            Type
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-peach);color:var(--c-cat-peach-ink);">
            R
          </span>
          <span class="text-[11px] text-ink-500">
            Resource
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-lilac);color:var(--c-cat-lilac-ink);">
            R
          </span>
          <span class="text-[11px] text-ink-500">
            Record
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-lilac);color:var(--c-cat-lilac-ink);">
            F
          </span>
          <span class="text-[11px] text-ink-500">
            Flags
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-teal);color:var(--c-cat-teal-ink);">
            V
          </span>
          <span class="text-[11px] text-ink-500">
            Variant
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-teal);color:var(--c-cat-teal-ink);">
            E
          </span>
          <span class="text-[11px] text-ink-500">
            Enum
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-pink);color:var(--c-cat-pink-ink);">
            M
          </span>
          <span class="text-[11px] text-ink-500">
            Module
          </span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <span class="sigil" style="background:var(--c-cat-plum);color:var(--c-cat-plum-ink);">
